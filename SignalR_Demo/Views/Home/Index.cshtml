@{
    ViewData["Title"] = "SignalR Real-time Chat";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Ứng dụng Chat Thời gian thực</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <input type="text" id="userInput" class="form-control" placeholder="Tên của bạn..." value="Sinh viên 49.01.104.119" />
                    </div>
                    <div class="mb-3">
                        <textarea id="messageInput" class="form-control" placeholder="Nhập tin nhắn..." rows="2"></textarea>
                    </div>
                    <button id="sendButton" class="btn btn-success w-100">Gửi tin nhắn</button>
                </div>
                <div class="card-footer bg-light" style="height: 300px; overflow-y: auto;">
                    <ul id="messagesList" class="list-unstyled"></ul>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

<script>
    // 1. Khởi tạo kết nối tới Hub
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .build();

    // 2. Lắng nghe sự kiện "ReceiveMessage" từ Server gửi xuống
    connection.on("ReceiveMessage", (user, message) => {
        const li = document.createElement("li");
        li.innerHTML = `<strong>${user}:</strong> ${message}`;
        li.className = "border-bottom py-2";
        document.getElementById("messagesList").appendChild(li);
    });

    // 3. Bắt đầu kết nối
    connection.start().catch(err => console.error(err.toString()));

    // 4. Bắt sự kiện Click nút gửi
    document.getElementById("sendButton").addEventListener("click", event => {
        const user = document.getElementById("userInput").value;
        const message = document.getElementById("messageInput").value;

        // Gọi hàm "SendMessage" trên Server Hub
        connection.invoke("SendMessage", user, message).catch(err => console.error(err.toString()));

        document.getElementById("messageInput").value = ""; // Xóa nội dung sau khi gửi
        event.preventDefault();
    });
</script>