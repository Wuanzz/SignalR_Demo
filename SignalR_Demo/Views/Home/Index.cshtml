@model List<SignalR_Demo.Models.ChatMessage>
@{
    Layout = null; // Xóa bỏ Header và Footer mặc định của ASP.NET Core
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Phòng Chat Chung</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        /* CSS Tùy chỉnh cho Giao diện Chat */
        .chat-container {
            height: 500px;
            overflow-y: auto;
            background-color: #f8f9fa;
            padding: 20px;
            border-radius: 8px;
            border: 1px solid #dee2e6;
            display: flex;
            flex-direction: column;
        }

        .message-row {
            width: 100%;
            display: flex;
            flex-direction: column;
            margin-bottom: 15px;
        }

        /* Bong bóng chat chung */
        .chat-bubble {
            max-width: 75%;
            padding: 10px 15px;
            border-radius: 20px;
            position: relative;
        }

        .sender-name {
            font-size: 0.8rem;
            color: #6c757d;
            margin-bottom: 4px;
        }

        /* Tin nhắn của mình (Nằm bên phải, màu xanh) */
        .row-mine {
            align-items: flex-end;
        }

            .row-mine .chat-bubble {
                background-color: #0d6efd;
                color: white;
                border-bottom-right-radius: 4px;
            }

            .row-mine .sender-name {
                display: none;
            }

        /* Tin nhắn của người khác (Nằm bên trái, màu xám) */
        .row-theirs {
            align-items: flex-start;
        }

            .row-theirs .chat-bubble {
                background-color: #e4e6eb;
                color: #050505;
                border-bottom-left-radius: 4px;
            }

        /* Thông báo hệ thống */
        .system-message {
            text-align: center;
            color: #adb5bd;
            font-size: 0.85rem;
            font-style: italic;
            margin: 10px 0;
            width: 100%;
        }

        /* Hiệu ứng đang gõ */
        #typingIndicator {
            font-size: 0.85rem;
            color: #6c757d;
            font-style: italic;
            display: none;
            margin-top: 10px;
        }

        /* Ảnh trong chat */
        .chat-image {
            max-width: 250px; /* Giới hạn độ rộng ảnh */
            border-radius: 10px;
            margin-top: 5px;
            cursor: pointer;
            transition: transform 0.2s;
            border: 1px solid #ddd;
        }

        /* Hiệu ứng khi hover vào ảnh */
        .chat-image:hover {
            transform: scale(1.02);
        }
    </style>
</head>
<body class="bg-light">

    <div class="container mt-2 text-end">
        <span class="me-2 text-muted">Xin chào, <strong class="text-dark">@User.Identity?.Name</strong>!</span>
        <a href="/Account/Logout" class="btn btn-sm btn-outline-danger">Đăng xuất</a>
    </div>

    <div class="container mt-3">
        <div class="row justify-content-center">
            <div class="row">
                <div class="col-md-3 mb-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-white border-bottom py-3">
                            <h6 class="mb-0 fw-bold text-success">
                                <span class="me-1">●</span> Đang hoạt động (<span id="onlineCount">0</span>)
                            </h6>
                        </div>
                        <div class="card-body p-2" style="overflow-y: auto; max-height: 500px;">
                            <ul id="onlineUsersList" class="list-group list-group-flush">
                                <li class="list-group-item text-muted text-center small">Đang tải...</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="col-md-9">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-3">
                            <h5 class="mb-0 fw-bold text-primary">Phòng Chat Chung</h5>
                        </div>

                        <div class="card-body p-0">
                            <div id="chatContainer" class="chat-container m-3 shadow-inner">
                                <div class="system-message">Chào mừng đến với hệ thống chat!</div>

                                @if (Model != null)
                                {
                                    @foreach (var msg in Model)
                                    {
                                        var isMine = msg.User == User.Identity?.Name;

                                        // C# Logic: Kiểm tra xem tin nhắn có phải là đường dẫn ảnh không
                                        var isImage = msg.Message.StartsWith("/uploads/") ||
                                        msg.Message.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) ||
                                        msg.Message.EndsWith(".png", StringComparison.OrdinalIgnoreCase) ||
                                        msg.Message.EndsWith(".gif", StringComparison.OrdinalIgnoreCase) ||
                                        msg.Message.EndsWith(".webp", StringComparison.OrdinalIgnoreCase);

                                        <div class="message-row @(isMine ? "row-mine" : "row-theirs")">
                                            @if (!isMine)
                                            {
                                                <div class="sender-name">@msg.User</div>
                                            }

                                            @if (isImage)
                                            {
                                                <img src="@msg.Message" class="chat-image shadow-sm" alt="Đã gửi một ảnh" title="@msg.Timestamp.ToString("HH:mm dd/MM/yyyy")" />
                                            }
                                            else
                                            {
                                                <div class="chat-bubble shadow-sm" title="@msg.Timestamp.ToString("HH:mm dd/MM/yyyy")">
                                                    @msg.Message
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        </div>

                        <div class="card-footer bg-white border-top p-3">
                            <div id="typingIndicator">Ai đó đang gõ...</div>
                            <div class="row g-2 align-items-center mt-1">

                                <div class="col-md-1 text-center">
                                    <input type="file" id="fileInput" accept="image/*" style="display: none;" />
                                    <button id="imgButton" class="btn btn-outline-secondary w-100" title="Gửi ảnh từ máy tính">
                                        📷
                                    </button>
                                </div>

                                <div class="col-md-9">
                                    <input type="text" id="messageInput" class="form-control" placeholder="Nhập tin nhắn..." autocomplete="off" />
                                </div>
                                <div class="col-md-2">
                                    <button id="sendButton" class="btn btn-primary w-100 fw-bold">Gửi</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder().withUrl("/chatHub").build();
        const chatContainer = document.getElementById("chatContainer");
        let typingTimer;

        // Lấy tên người dùng hiện tại trực tiếp từ Razor để JavaScript sử dụng
        const currentUser = '@Html.Raw(User.Identity?.Name)';

        function scrollToBottom() {
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }

        // Nhận tin nhắn
        connection.on("ReceiveMessage", (user, message) => {
            const isMine = user === currentUser;
            const rowDiv = document.createElement("div");
            rowDiv.className = `message-row ${isMine ? 'row-mine' : 'row-theirs'}`;

            // Kiểm tra xem tin nhắn có chứa file đường dẫn ảnh từ thư mục upload không
            const isImageUrl = message.startsWith("/uploads/") || message.match(/\.(jpeg|jpg|gif|png|webp)$/i) != null;

            let contentHtml = "";
            if (isImageUrl) {
                contentHtml = `<img src="${message}" class="chat-image shadow-sm" alt="Đã gửi một ảnh" />`;
            } else {
                contentHtml = `<div class="chat-bubble shadow-sm">${message}</div>`;
            }

            rowDiv.innerHTML = `
                ${!isMine ? `<div class="sender-name">${user}</div>` : ''}
                ${contentHtml}
            `;

            chatContainer.appendChild(rowDiv);
            scrollToBottom();
            document.getElementById("typingIndicator").style.display = "none";
        });

        // Nhận thông báo hệ thống
        connection.on("ReceiveSystemMessage", (message) => {
            const div = document.createElement("div");
            div.className = "system-message";
            div.textContent = message;
            chatContainer.appendChild(div);
            scrollToBottom();
        });

        // Nhận tín hiệu đang gõ
        connection.on("UserTyping", (user) => {
            const indicator = document.getElementById("typingIndicator");
            indicator.textContent = `${user} đang gõ...`;
            indicator.style.display = "block";

            clearTimeout(typingTimer);
            typingTimer = setTimeout(() => {
                indicator.style.display = "none";
            }, 2000);
        });

        connection.start().catch(err => console.error(err.toString()));

        // Xử lý gửi tin nhắn
        document.getElementById("sendButton").addEventListener("click", sendMessage);

        document.getElementById("messageInput").addEventListener("keypress", function (e) {
            if (e.key === 'Enter') {
                sendMessage();
            } else {
                // Gửi tên người đang gõ lên Hub
                connection.invoke("Typing", currentUser).catch(err => console.error(err.toString()));
            }
        });

		// Xử lý gửi ảnh
        document.getElementById("imgButton").addEventListener("click", () => {
            document.getElementById("fileInput").click(); // Mở hộp thoại chọn file
        });

		// Khi người dùng chọn file, sẽ tự động gửi ảnh lên Server
        document.getElementById("fileInput").addEventListener("change", async function() {
            const file = this.files[0];
            if (!file) return;

            // Hiển thị chữ đang tải để UX tốt hơn
            const indicator = document.getElementById("typingIndicator");
            indicator.textContent = "Đang tải ảnh lên...";
            indicator.style.display = "block";

            // Chuẩn bị dữ liệu gửi đi (FormData)
            const formData = new FormData();
            formData.append("file", file);

            try {
                // Gửi HTTP POST lên API UploadImage
                const response = await fetch('/Home/UploadImage', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (response.ok && data.url) {
                    // Upload thành công, dùng SignalR gửi URL đó cho mọi người
                    connection.invoke("SendMessage", data.url).catch(err => console.error(err.toString()));
                } else {
                    alert("Lỗi tải ảnh: " + data.message);
                }
            } catch (err) {
                console.error("Lỗi hệ thống:", err);
                alert("Không thể tải ảnh lên Server.");
            } finally {
                indicator.style.display = "none";
                this.value = ''; // Reset thẻ input file
            }
        });

        function sendMessage() {
            const messageInput = document.getElementById("messageInput");
            const message = messageInput.value;

            if (message.trim() !== "") {
                // Do Hub đã tự nhận diện tên người gửi, ta chỉ cần truyền nội dung tin nhắn lên
                connection.invoke("SendMessage", message).catch(err => console.error(err.toString()));
                messageInput.value = "";
                messageInput.focus();
            }
        }

        window.onload = function() {
            scrollToBottom();
        };

		// Cập nhật danh sách người dùng trực tuyến
        connection.on("UpdateOnlineUsers", (users) => {
            const userList = document.getElementById("onlineUsersList");
            const onlineCount = document.getElementById("onlineCount");
    
            // Cập nhật số lượng
            onlineCount.innerText = users.length;
    
            // Xóa trắng danh sách cũ
            userList.innerHTML = "";
    
            // Vẽ lại danh sách mới
            users.forEach(u => {
                const li = document.createElement("li");
                li.className = "list-group-item border-0 px-2 py-2 d-flex align-items-center";
        
                // Kiểm tra nếu là chính mình thì bôi đậm lên cho dễ nhìn
                const isMe = u === currentUser;
        
                li.innerHTML = `
                    <span class="text-success me-2" style="font-size: 0.8rem;">●</span>
                    <span class="${isMe ? 'fw-bold' : ''}">${u} ${isMe ? '(Bạn)' : ''}</span>
                `;
                userList.appendChild(li);
            });
        });
    </script>
</body>
</html>